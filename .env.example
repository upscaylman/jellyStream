# JellyStream Environment Variables
# Copy this file to .env and fill in your values

# Jellyfin server URL (optional — can be entered in-app)
# JELLYFIN_SERVER_URL=http://your-server:8096

# TMDB API key (for collection metadata & trending carousel)
# Get yours at: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_api_key
